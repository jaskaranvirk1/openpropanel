# Normalise line endings to LF in the repository and on checkout, so the shell
# scripts, systemd unit and configs work correctly on the Linux target even when
# authored/committed from Windows.
* text=auto eol=lf

*.sh      text eol=lf
*.go      text eol=lf
*.service text eol=lf
*.spec    text eol=lf
Makefile  text eol=lf

